# ============================================
# arc-nano-kit Demo App — Environment Variables
# ============================================

# Seller wallet configuration
# Generate a new wallet: npx viem generate-key
SELLER_PRIVATE_KEY=0x_your_private_key_here
SELLER_ADDRESS=0x_your_wallet_address_here

# Arc Testnet configuration
ARC_RPC_URL=https://rpc.testnet.arc.network
CHAIN_ID=5042002

# Optional: Supabase for persistent usage tracking
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Optional: Circle Developer Console
# CIRCLE_API_KEY=your-circle-api-key

# Demo configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
